generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 역할(role): STUDENT, PARENT, COACH, DIRECTOR, TEACHER
// 종목(sport): 자유 문자열 (축구, 농구, 야구 ...)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  nickname  String?  // 커뮤니티 표시 이름(닉네임)
  role      String   @default("STUDENT")
  sport     String?  // 주 종목
  region    String?  // 활동/거주 지역
  school    String?  // 소속 학교
  team      String?  // 소속 팀/클럽
  bio       String?  // 한 줄 소개
  avatar    String?  // 프로필 이미지 URL
  cover     String?  // 커버 이미지 URL
  themeColor String? // 프로필 테마 색상 키(brand/violet/emerald/rose/amber/slate)
  instagram String?  // 인스타그램 아이디
  youtube   String?  // 유튜브 채널 URL
  kakaoId   String?  @unique // 카카오 로그인 연동 ID
  verified  Boolean  @default(false) // 인증 지도자 뱃지
  isAdmin   Boolean  @default(false) // 관리자 계정
  suspended Boolean  @default(false) // 신고 처리에 따른 이용 정지
  points    Int      @default(0) // 커뮤니티 활동 포인트(추천 등)
  agreedAt      DateTime? // 이용약관·개인정보 필수 동의 시각(동의 이력)
  marketingOptIn Boolean  @default(false) // 마케팅 정보 수신(선택) 동의
  deletedAt     DateTime? // 회원 탈퇴(소프트 삭제) 시각 — 30일 후 완전 삭제, 그 전 재로그인 시 복구
  isBot         Boolean  @default(false) // 데모·마케팅용 자동 활동 계정 표시
  createdAt DateTime @default(now())

  careers              Career[]
  verificationRequests VerificationRequest[]
  credentials          Credential[]
  postLikes            PostLike[]
  commentLikes         CommentLike[]
  recruitmentLikes     RecruitmentLike[]
  reportsMade          Report[]              @relation("ReportsMade")
  notifications        Notification[]        @relation("Notifications")
  posts           Post[]
  comments        Comment[]
  recruitments    Recruitment[]
  proposals       Proposal[]
  sentMsgs        Message[]  @relation("SentMessages")
  membershipsA    ChatRoom[] @relation("UserA")
  membershipsB    ChatRoom[] @relation("UserB")
  reviewsWritten  Review[]   @relation("ReviewsWritten")
  reviewsReceived Review[]   @relation("ReviewsReceived")
  paymentsPayer   Payment[]  @relation("PaymentsPayer")
  paymentsPayee   Payment[]  @relation("PaymentsPayee")
  inquiries       Inquiry[]
  resetTokens     PasswordResetToken[]
}

// 비밀번호 재설정 토큰 (가입 이메일로 발송)
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// 경력 (인스타 프로필에 표시)
model Career {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String  // 예: "OO고등학교 농구부 코치"
  org       String? // 소속
  startYear Int?
  endYear   Int?    // null이면 현재
  detail    String?
  order     Int     @default(0)
}

// 커뮤니티 글
// category: FREE(자유) | QUESTION(질문) | INFO(정보/팁) | TEAMUP(같이운동) | REVIEW(후기)
model Post {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category  String   @default("FREE")
  sport     String? // 종목 (자유글은 선택)
  title     String
  content   String
  views     Int      @default(0)
  createdAt DateTime @default(now())

  comments Comment[]
  likes    PostLike[]
}

// 게시글 좋아요 (사용자당 1회)
model PostLike {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  recommended Boolean @default(false) // 글 작성자가 추천(채택)한 답변
  parentId  String? // 답글이면 부모 댓글 id
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  likes     CommentLike[]
  createdAt DateTime @default(now())
}

// 댓글/답글 좋아요 (사용자당 1회)
model CommentLike {
  id        String  @id @default(cuid())
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

// 모집공고 (학생/학부모가 올림)
// serviceType: COUNSELING(상담) | LESSON(레슨)
// status: OPEN | MATCHED | CLOSED
model Recruitment {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sport       String
  serviceType String   @default("LESSON")
  title       String
  content     String
  region      String?
  budget      String?  // 예: "회당 5만원", "협의"
  status      String   @default("OPEN")
  views       Int      @default(0) // 조회수 (중복 카운팅)
  createdAt   DateTime @default(now())

  proposals Proposal[]
  likes     RecruitmentLike[]
}

// 모집공고 하트 (사용자당 1회)
model RecruitmentLike {
  id            String      @id @default(cuid())
  recruitmentId String
  recruitment   Recruitment @relation(fields: [recruitmentId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([recruitmentId, userId])
}

// 제안 (코치/감독/레슨선생님이 모집공고에 제안)
// status: PENDING | ACCEPTED | REJECTED
model Proposal {
  id            String      @id @default(cuid())
  recruitmentId String
  recruitment   Recruitment @relation(fields: [recruitmentId], references: [id], onDelete: Cascade)
  proposerId    String
  proposer      User        @relation(fields: [proposerId], references: [id], onDelete: Cascade)
  message       String
  price         String?
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now())

  reviews Review[]
}

// 알림
// type: COMMENT | REPLY | POST_LIKE | COMMENT_LIKE | PROPOSAL | MATCH | MESSAGE | CONSULT | RECOMMEND
model Notification {
  id        String   @id @default(cuid())
  userId    String // 받는 사람
  user      User     @relation("Notifications", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String? // 발생시킨 사람
  type      String
  message   String
  link      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// 신고 — 부적절한 회원/게시물/댓글
// targetType: USER | POST | COMMENT | RECRUITMENT
// status: PENDING | RESOLVED | DISMISSED
model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  reason     String // 신고 사유(카테고리)
  detail     String? // 상세 설명
  status     String   @default("PENDING")
  adminNote  String?
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
}

// 패스키(WebAuthn) 자격증명 — Face ID / 지문 / 기기 PIN 로그인
model Credential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique // base64url 인코딩된 credential ID
  publicKey    Bytes
  counter      Int      @default(0)
  transports   String? // JSON 배열 문자열
  deviceName   String?
  createdAt    DateTime @default(now())
}

// 지도자 인증 신청 (코치/감독/레슨선생님 → 관리자 승인 시 user.verified = true)
// status: PENDING | APPROVED | REJECTED
model VerificationRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  realName    String? // 실명
  credential  String // 자격증/경력 등 증빙 설명
  evidenceUrl String? // 증빙 이미지 URL
  status      String    @default("PENDING")
  reviewNote  String? // 관리자 코멘트(거절 사유 등)
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?
}

// 후기·별점 (매칭 성사 = 제안 ACCEPTED 된 두 당사자끼리만 상호 작성)
model Review {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("ReviewsWritten", fields: [authorId], references: [id], onDelete: Cascade)
  targetId   String
  target     User     @relation("ReviewsReceived", fields: [targetId], references: [id], onDelete: Cascade)
  rating     Int // 1~5
  content    String
  createdAt  DateTime @default(now())

  // 한 매칭당 작성자 1명이 1번만 (상호이므로 두 방향 각각 1개)
  @@unique([proposalId, authorId])
}

// 1:1 채팅방
model ChatRoom {
  id          String    @id @default(cuid())
  userAId     String
  userA       User      @relation("UserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId     String
  userB       User      @relation("UserB", fields: [userBId], references: [id], onDelete: Cascade)
  lastReadAAt DateTime? // userA가 마지막으로 읽은 시각
  lastReadBAt DateTime? // userB가 마지막으로 읽은 시각
  createdAt   DateTime  @default(now())
  messages    Message[]
  payments    Payment[]

  @@unique([userAId, userBId])
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  kind      String   @default("TEXT") // TEXT | PAYMENT
  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

// 채팅 내 결제 (안전결제) — status: REQUESTED | PAID | CANCELED | REFUNDED
model Payment {
  id        String    @id @default(cuid())
  roomId    String?
  room      ChatRoom? @relation(fields: [roomId], references: [id], onDelete: SetNull)
  payerId   String // 결제하는 사람(학생/학부모)
  payer     User      @relation("PaymentsPayer", fields: [payerId], references: [id], onDelete: Cascade)
  payeeId   String // 정산 받는 사람(코치/선생님)
  payee     User      @relation("PaymentsPayee", fields: [payeeId], references: [id], onDelete: Cascade)
  amount    Int
  memo      String?
  status    String    @default("REQUESTED")
  method    String? // 결제 수단(데모: "가상결제")
  createdAt DateTime  @default(now())
  paidAt    DateTime?
  message   Message?

  @@index([status, createdAt])
}

// 1:1 문의 — status: OPEN | ANSWERED | CLOSED
model Inquiry {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  email     String
  category  String    @default("GENERAL") // GENERAL | PAYMENT | REPORT | PARTNER | ETC
  subject   String
  message   String
  status    String    @default("OPEN")
  reply     String?
  repliedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([status, createdAt])
}

// 학교 DB (체육 특기자·입시 상담용) — category: MIDDLE | HIGH | UNIV | CLUB
model School {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("HIGH")
  region    String?
  sports    String? // 쉼표로 구분된 종목 목록
  homepage  String?
  note      String?
  createdAt DateTime @default(now())

  @@index([name])
}

// 접속·유입 로그 (통계용)
model AccessLog {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// 오류/버그 로그
model ErrorLog {
  id        String   @id @default(cuid())
  message   String
  stack     String?
  path      String?
  userId    String?
  digest    String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([resolved, createdAt])
}

// 사이트 설정(홈 레이아웃 등) 단순 key-value
model Setting {
  key   String @id
  value String
}

// 홈 화면 스포츠 이슈/뉴스
model NewsItem {
  id        String   @id @default(cuid())
  sport     String
  title     String // 헤드라인
  summary   String // 목록/미리보기용 한두 줄 요약
  body      String? // 기사 본문(전체 내용)
  source    String?
  imageUrl  String?
  createdAt DateTime @default(now())
}
