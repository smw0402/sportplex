# ── 데이터베이스 (PostgreSQL) ──
# 로컬·프로덕션 모두 Postgres 사용. Neon(무료) 연결 문자열을 넣으세요.
# 예) postgresql://user:pass@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# 세션 서명 비밀키 — 반드시 임의의 긴 문자열로 교체
# 생성: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# ── 이미지 업로드 (Vercel Blob) ──
# 이 토큰이 있으면 Blob에 저장, 없으면(로컬) public/uploads 디스크에 저장.
# Vercel 대시보드 → Storage → Blob 에서 발급.
BLOB_READ_WRITE_TOKEN=""

# ── 패스키(Face ID/지문) ──
# 로컬: 아래 기본값. 배포: 실제 도메인으로 교체.
# 예) WEBAUTHN_RP_ID="sportplex.app"  WEBAUTHN_ORIGIN="https://sportplex.app"
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3000"

# ── 카카오 로그인 (OAuth) ──
# 카카오 개발자 콘솔(developers.kakao.com)에서 앱 생성 후:
#  1) [앱 키] → REST API 키를 KAKAO_REST_API_KEY 에 입력
#  2) [카카오 로그인] 활성화 ON, 동의항목에 닉네임/이메일 추가
#  3) [Redirect URI]에 `<사이트주소>/api/auth/kakao/callback` 등록
#     (로컬: http://localhost:3000/api/auth/kakao/callback,
#      배포: https://<도메인>/api/auth/kakao/callback)
#  4) (선택) 보안 강화를 위해 Client Secret 발급 후 KAKAO_CLIENT_SECRET 입력
KAKAO_REST_API_KEY=""
KAKAO_CLIENT_SECRET=""

# ── 비밀번호 재설정 메일 (Resend) ──
# resend.com 가입 → API Keys에서 발급 (re_...). 무료 플랜 제공.
# 실제 사용자에게 보내려면 Resend에서 발신 도메인 인증 필요(EMAIL_FROM에 해당 도메인 주소).
# 도메인 인증 전에는 onboarding@resend.dev 로 계정 소유자 메일에만 발송 가능.
RESEND_API_KEY=""
EMAIL_FROM="Sportplex <onboarding@resend.dev>"

# ── 크론(자동 작업) 시크릿 ──
# 데모 계정 자동 활동(/api/cron/activity), 탈퇴 계정 30일 후 완전삭제(/api/cron/purge) 보호용.
# Vercel Cron이 자동으로 Authorization: Bearer $CRON_SECRET 헤더를 붙여 호출함.
# 생성: openssl rand -hex 24
CRON_SECRET=""
