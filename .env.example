# ── 데이터베이스 (PostgreSQL) ──
# 로컬·프로덕션 모두 Postgres 사용. Neon(무료) 연결 문자열을 넣으세요.
# 예) postgresql://user:pass@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# 세션 서명 비밀키 — 반드시 임의의 긴 문자열로 교체
# 생성: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# ── 이미지 업로드 (Vercel Blob) ──
# 이 토큰이 있으면 Blob에 저장, 없으면(로컬) public/uploads 디스크에 저장.
# Vercel 대시보드 → Storage → Blob 에서 발급.
BLOB_READ_WRITE_TOKEN=""

# ── 패스키(Face ID/지문) ──
# 로컬: 아래 기본값. 배포: 실제 도메인으로 교체.
# 예) WEBAUTHN_RP_ID="sportplex.app"  WEBAUTHN_ORIGIN="https://sportplex.app"
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3000"
